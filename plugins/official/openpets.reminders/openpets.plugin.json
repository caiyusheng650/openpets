{
  "manifestVersion": 3,
  "id": "openpets.reminders",
  "name": "$t:plugin.name",
  "description": "$t:plugin.description",
  "version": "1.0.0",
  "runtime": "javascript",
  "icon": "bell",
  "sdkVersion": "3.0.0",
  "entry": "index.js",
  "assets": {
    "icons": {
      "reminder": "assets/reminder.svg"
    }
  },
  "permissions": [
    "pet:speak",
    "pet:interact",
    "audio",
    "schedule",
    "storage",
    "commands",
    "status",
    "notify"
  ],
  "configSchema": {
    "soundEnabled": {
      "type": "boolean",
      "default": true,
      "label": "$t:config.soundEnabled.label",
      "description": "$t:config.soundEnabled.description"
    },
    "osNotification": {
      "type": "boolean",
      "default": true,
      "label": "$t:config.osNotification.label",
      "description": "$t:config.osNotification.description"
    },
    "customSound": {
      "type": "sound",
      "label": "$t:config.customSound.label",
      "description": "$t:config.customSound.description"
    }
  }
}
